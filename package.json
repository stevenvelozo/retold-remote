{
    "name": "retold-remote",
    "version": "0.0.28",
    "description": "Retold Remote - NAS media browser with gallery views and keyboard navigation",
    "main": "source/Pict-RetoldRemote-Bundle.js",
    "bin": {
        "retold-remote": "source/cli/RetoldRemote-CLI-Run.js",
        "rr": "source/cli/RetoldRemote-CLI-Run.js",
        "retold-stack": "source/cli/RetoldRemote-Stack-Run.js"
    },
    "files": [
        "source/",
        "web-application/",
        "html/",
        "css/",
        "docs/",
        "README.md",
        "LICENSE"
    ],
    "scripts": {
        "start": "node source/cli/RetoldRemote-CLI-Run.js",
        "stack": "node source/cli/RetoldRemote-Stack-Run.js",
        "build": "npx quack build && npx quack copy",
        "test": "npx mocha -u tdd --exit --timeout 30000 test/*_tests.js",
        "prepack": "npm run build",
        "tests": "npx mocha -u tdd --exit -R spec --grep",
        "coverage": "npx nyc --reporter=lcov --reporter=text-lcov npx mocha -- -u tdd -R spec",
        "examples": "npx quack examples",
        "docs": "npx quack prepare-docs ./docs -d ./modules",
        "docs-serve": "npx quack docs-serve ./docs"
    },
    "retoldBeacon": {
        "displayName": "Retold Remote",
        "description": "NAS media browser with gallery views and keyboard navigation; serves a content folder over HTTP and registers as a beacon.",
        "category": "content",
        "mode": "standalone-service",
        "bin": "source/cli/RetoldRemote-CLI-Run.js",
        "argTemplate": [
            "serve",
            {
                "fromLabPath": "ContentPath"
            },
            "-p",
            {
                "fromLabPath": "Port"
            },
            "-u",
            {
                "fromLabPath": "UltravisorURL"
            }
        ],
        "healthCheck": {
            "path": "/"
        },
        "defaultPort": 7777,
        "requiresUltravisor": true,
        "configForm": {
            "Fields": [
                {
                    "Name": "HostContentPath",
                    "Label": "Host folder to serve",
                    "Type": "text",
                    "Required": true,
                    "Help": "Absolute path on the host whose contents will be served; bind-mounted read-only into the container at /app/content."
                }
            ]
        },
        "docker": {
            "image": "retold-remote",
            "dockerfile": "retold-remote.Dockerfile",
            "dataMountPath": "/app/data",
            "configMountPath": "/app/data/config.json",
            "contentMountPath": "/app/content",
            "exposedPort": 7777,
            "configMounts": [
                {
                    "ConfigField": "HostContentPath",
                    "Target": "/app/content",
                    "ReadOnly": true
                }
            ]
        }
    },
    "author": "steven velozo <steven@velozo.com>",
    "license": "MIT",
    "dependencies": {
        "@xmldom/xmldom": "^0.9.10",
        "dcraw": "^1.0.3",
        "epubjs": "^0.3.93",
        "exifr": "^7.1.3",
        "fable": "^3.1.71",
        "fable-serviceproviderbase": "^3.0.19",
        "fable-ultravisor-client": "^0.0.1",
        "node-unrar-js": "^2.0.2",
        "orator": "^6.1.0",
        "orator-conversion": "^1.0.12",
        "orator-serviceserver-restify": "^2.0.10",
        "parime": "^1.0.4",
        "pdf-parse": "^2.4.5",
        "pict": "^1.0.365",
        "pict-application": "^1.0.33",
        "pict-provider": "^1.0.12",
        "pict-section-code": "^1.0.4",
        "pict-section-filebrowser": "^0.0.2",
        "pict-service-commandlineutility": "^1.0.19",
        "pict-view": "^1.0.68",
        "retold-content-system": "^1.0.21",
        "retold-sharp": "^0.0.2",
        "ultravisor": "^1.0.29",
        "ultravisor-beacon": "^0.0.13",
        "ws": "^8.20.0",
        "yauzl": "^3.3.0"
    },
    "devDependencies": {
        "pict-docuserve": "^0.1.5",
        "puppeteer": "^24.42.0",
        "quackage": "^1.1.3"
    },
    "copyFilesSettings": {
        "whenFileExists": "overwrite"
    },
    "copyFiles": [
        {
            "from": "./html/*",
            "to": "./web-application/"
        },
        {
            "from": "./css/**",
            "to": "./web-application/css/"
        },
        {
            "from": "./node_modules/pict/dist/pict.min.js",
            "to": "./web-application/js/"
        },
        {
            "from": "./node_modules/pict/dist/pict.min.js.map",
            "to": "./web-application/js/"
        },
        {
            "from": "./node_modules/jszip/dist/jszip.min.js",
            "to": "./web-application/js/"
        },
        {
            "from": "./node_modules/epubjs/dist/epub.min.js",
            "to": "./web-application/js/"
        },
        {
            "from": "./node_modules/pict-docuserve/dist/pict-docuserve.min.js",
            "to": "./web-application/js/"
        },
        {
            "from": "./node_modules/pict-docuserve/css/docuserve.css",
            "to": "./web-application/css/"
        },
        {
            "from": "./docs/*.md",
            "to": "./web-application/docs/"
        }
    ],
    "mocha": {
        "diff": true,
        "extension": [
            "js"
        ],
        "package": "./package.json",
        "reporter": "spec",
        "slow": "75",
        "timeout": "5000",
        "ui": "tdd",
        "spec": "test/*_tests.js",
        "watch-files": [
            "source/**/*.js",
            "test/**/*.js"
        ],
        "watch-ignore": [
            "lib/vendor"
        ]
    }
}
